# IMCs environment example
MP_API_KEY=your_materials_project_api_key
IMCS_SECRET_KEY=your_production_secret_key
IMCS_API_URL=http://localhost:8000

# Materials Project query tuning
MP_MAX_ELEMENTS=5
MP_SEARCH_ALL_ELEMENTS=0
MP_MAX_FAILURES=3
MP_MAX_RETRIES=2
MP_QUERY_SLEEP=0.2
MP_BACKOFF_BASE=1.5

# Evidence auto-fill (P2)
IMCS_EVIDENCE_AUTO_FILL=1
IMCS_EVIDENCE_GAP_ROUNDS=1
